# Copy this file to nj_rfp_monitor/.env and fill in real values.
# All other tools (scrapers/, nj_cannabis/) read from the same env vars.

# --- Required for rfp-monitor and deep-dive ---
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Required for Notion-backed monitoring URL list (rfp-monitor) ---
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional but strongly recommended ---
# Without OPENAI_API_KEY, every LLM call falls back to keyword/regex extraction.
# The pipelines still run end-to-end, quality just drops.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: email alerts when a new RFP hit is found ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ABBAS_EMAIL=
